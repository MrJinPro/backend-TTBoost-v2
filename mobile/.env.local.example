# Local mobile config. This file is safe to copy to .env.local and keep uncommitted.

API_BASE_URL=https://api.ttboost.pro
WS_URL=wss://api.ttboost.pro/v2/ws
MEDIA_BASE_URL=https://media.ttboost.pro

# Spotify mobile auth uses PKCE, so client secret is NOT required here.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_REDIRECT_URI=novaboost://spotify-auth