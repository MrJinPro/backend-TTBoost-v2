ENV=prod
# Базовый URL API (используется для корневого хоста и абсолютных ссылок по умолчанию)
SERVER_HOST=https://api.ttboost.pro
# Отдельный медиа-домен для раздачи файлов
MEDIA_BASE_URL=https://media.ttboost.pro
# Каталог на диске, где хранятся файлы пользователей (по умолчанию app/static/sounds)
# MEDIA_ROOT=/var/ttboost/media/sounds
TTS_BASE_URL=https://media.ttboost.pro
SIGN_SERVER_URL=https://sign.example.com/sign
SIGN_API_KEY=your_eulerstream_api_key_here
# SIGN_API_URL=https://tiktok.eulerstream.com
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# Microsoft Azure Speech TTS (официальный способ для Microsoft голосов на сервере).
# Нужен ресурс Speech в Azure + ключ и регион.
# AZURE_SPEECH_KEY=...
# AZURE_SPEECH_REGION=westeurope
# Опционально: формат (mp3)
# AZURE_TTS_OUTPUT_FORMAT=audio-16khz-32kbitrate-mono-mp3
# Таймауты (сек)
# AZURE_TTS_TIMEOUT_SECONDS=20
# EDGE_TTS_TIMEOUT_SECONDS=35

# JWT секрет для токенов авторизации v2 (логин/пароль)
JWT_SECRET=change_me_please

# База данных (по умолчанию SQLite локально, для продакшена PostgreSQL)
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/ttboost

# Если в Supabase используется отдельная схема (чтобы не трогать public):
# DB_SCHEMA=mobile

# Если DNS у Supabase отдаёт IPv6 первым и соединение нестабильно — можно форсить IPv4 адрес:
# DB_HOSTADDR=1.2.3.4

# Supabase Auth (email+password) — для обмена supabase access_token на JWT нашего backend.
# SUPABASE_URL=https://<project_ref>.supabase.co
# SUPABASE_JWT_AUD=authenticated
# SUPABASE_JWKS_URL=https://<project_ref>.supabase.co/auth/v1/keys

# Для проверки подтверждения email на стороне backend (через /auth/v1/user).
# Это публичный ключ (anon), его можно безопасно хранить в env.
# SUPABASE_ANON_KEY=eyJhbGciOi...

# В некоторых проектах Supabase JWKS endpoint может требовать заголовок `apikey`.
# Backend использует SUPABASE_ANON_KEY для загрузки JWKS.
# Также Supabase может подписывать токены ES256 (ECC P-256) или RS256 — оба поддерживаются.

# Таймаут и кэш JWKS (сек)
# SUPABASE_JWKS_TIMEOUT_SECONDS=8
# SUPABASE_JWKS_CACHE_TTL_SECONDS=600

# Требовать подтверждённый email при /v2/auth/supabase/exchange (по умолчанию 1).
# SUPABASE_ENFORCE_EMAIL_CONFIRMED=1

# Таймаут запроса к Supabase userinfo (сек)
# SUPABASE_USERINFO_TIMEOUT_SECONDS=8

# Опционально: выключить legacy регистрацию /v2/auth/register (для принудительного перехода на Supabase).
# DISABLE_LEGACY_REGISTER=1
